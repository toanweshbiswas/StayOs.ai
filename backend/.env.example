# ─────────────────────────────────────────────
# StayOs Backend — Environment Variables
# Copy this to .env and fill in the values
# ─────────────────────────────────────────────

# PostgreSQL database URL (from Supabase → Project Settings → Database → Connection string)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# JWT Secret — any long random string e.g. openssl rand -hex 32
JWT_SECRET="your-super-secret-jwt-key-here"

# Supabase project URL (from Supabase → Project Settings → API)
SUPABASE_URL="https://[PROJECT_REF].supabase.co"

# Supabase SERVICE ROLE key (from Supabase → Project Settings → API → service_role)
# ⚠️  NEVER expose this in the frontend — backend only!
SUPABASE_SERVICE_KEY="eyJh..."

# Supabase Storage bucket name (create this in Supabase → Storage)
SUPABASE_STORAGE_BUCKET="stayos-images"

# Allowed frontend origins for CORS (comma-separated)
# e.g. https://stayosai.netlify.app,https://stayosai-admin.netlify.app
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"

# Port (Render sets this automatically — don't change)
PORT=3001
